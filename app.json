{
  "expo": {
    "name": "GG Economy",
    "slug": "gg-economy-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "gg-economy",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ggeconomy.mobile",
      "infoPlist": {
        "NSDocumentsFolderUsageDescription": "GG Economy needs access to your documents to import bank statements.",
        "UIFileSharingEnabled": true,
        "LSSupportsOpeningDocumentsInPlace": true
      }
    },
    "android": {
      "package": "com.ggeconomy.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "navigationBarColor": "#FFFFFF",
      "navigationBarStyle": "dark",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "intentFilters": [
        {
          "action": "android.intent.action.SEND",
          "category": ["android.intent.category.DEFAULT"],
          "data": [
            {
              "mimeType": "text/csv"
            },
            {
              "mimeType": "application/x-ofx"
            },
            {
              "mimeType": "application/vnd.intu.qfx"
            },
            {
              "mimeType": "text/plain"
            },
            {
              "mimeType": "application/octet-stream"
            },
            {
              "mimeType": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
            },
            {
              "mimeType": "application/vnd.ms-excel"
            }
          ]
        },
        {
          "action": "android.intent.action.VIEW",
          "category": ["android.intent.category.DEFAULT", "android.intent.category.BROWSABLE"],
          "data": [
            {
              "scheme": "file",
              "pathPattern": ".*\\.csv"
            },
            {
              "scheme": "file",
              "pathPattern": ".*\\.ofx"
            },
            {
              "scheme": "file",
              "pathPattern": ".*\\.qif"
            },
            {
              "scheme": "file",
              "pathPattern": ".*\\.xlsx"
            },
            {
              "scheme": "file",
              "pathPattern": ".*\\.xls"
            },
            {
              "scheme": "content",
              "pathPattern": ".*\\.csv"
            },
            {
              "scheme": "content",
              "pathPattern": ".*\\.ofx"
            },
            {
              "scheme": "content",
              "pathPattern": ".*\\.qif"
            },
            {
              "scheme": "content",
              "pathPattern": ".*\\.xlsx"
            },
            {
              "scheme": "content",
              "pathPattern": ".*\\.xls"
            }
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-sqlite",
      "expo-secure-store",
      "expo-localization",
      "expo-web-browser",
      "expo-navigation-bar",
      [
        "expo-router",
        {
          "root": "./app"
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "8330e90e-6a7a-49a2-8b8d-940d89aeddbd"
      },
      "googleOAuth": {
        "webClientId": "316079469489-7oq375t2g6ph8b2ahq56611pjejc3oq7.apps.googleusercontent.com",
        "androidClientId": "316079469489-ht2ts297l15agje9fm8n3vfck093kb1a.apps.googleusercontent.com",
        "iosClientId": "YOUR_IOS_CLIENT_ID.apps.googleusercontent.com"
      },
      "router": {
        "root": "./app"
      }
    },
    "locales": {
      "pt-BR": "./src/i18n/locales/pt-BR.json",
      "en": "./src/i18n/locales/en.json"
    },
    "owner": "gutaolox"
  }
}

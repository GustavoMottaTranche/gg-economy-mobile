{
  "name": "gg-economy-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "e2e": "maestro test .maestro/flows",
    "e2e:smoke": "maestro test .maestro/flows/smoke-test.yaml",
    "e2e:import": "maestro test .maestro/flows/import-flow.yaml",
    "e2e:import:mock": "maestro test .maestro/flows/import-flow-mock.yaml",
    "e2e:manual": "maestro test .maestro/flows/manual-entry.yaml",
    "e2e:backup": "maestro test .maestro/flows/backup-flow.yaml",
    "e2e:backup:mock": "maestro test .maestro/flows/backup-flow-mock.yaml",
    "e2e:navigation": "maestro test .maestro/flows/navigation.yaml",
    "e2e:language": "maestro test .maestro/flows/language.yaml",
    "e2e:studio": "maestro studio",
    "build:dev": "eas build --profile development --platform all",
    "build:dev:android": "eas build --profile development --platform android",
    "build:dev:ios": "eas build --profile development --platform ios",
    "build:preview": "eas build --profile preview --platform all",
    "build:preview:android": "eas build --profile preview --platform android",
    "build:preview:ios": "eas build --profile preview --platform ios",
    "build:prod": "eas build --profile production --platform all",
    "build:prod:android": "eas build --profile production --platform android",
    "build:prod:ios": "eas build --profile production --platform ios",
    "build:local:android": "eas build --profile development --platform android --local",
    "submit:android": "eas submit --platform android --profile production",
    "submit:ios": "eas submit --platform ios --profile production"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "^9.1.0",
    "@shopify/flash-list": "2.0.2",
    "drizzle-orm": "^0.45.2",
    "expo": "^55.0.0",
    "expo-auth-session": "~55.0.15",
    "expo-background-fetch": "~55.0.15",
    "expo-constants": "^55.0.15",
    "expo-crypto": "~55.0.14",
    "expo-dev-client": "^55.0.30",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.17",
    "expo-localization": "~55.0.13",
    "expo-notifications": "~55.0.22",
    "expo-router": "~55.0.13",
    "expo-secure-store": "~55.0.13",
    "expo-splash-screen": "^55.0.19",
    "expo-sqlite": "~55.0.15",
    "expo-status-bar": "~55.0.5",
    "expo-task-manager": "~55.0.15",
    "expo-web-browser": "~55.0.14",
    "i18next": "^26.0.8",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-i18next": "^17.0.6",
    "react-native": "0.83.6",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-svg": "^15.15.3",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.3",
    "@babel/preset-typescript": "^7.28.5",
    "@react-native/babel-preset": "^0.85.2",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.0",
    "@types/react": "~19.2.10",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "babel-jest": "^29.7.0",
    "babel-preset-expo": "^55.0.19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-native": "^5.0.0",
    "fast-check": "^4.7.0",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.16",
    "prettier": "^3.8.3",
    "typescript": "~5.9.2"
  },
  "private": true
}
